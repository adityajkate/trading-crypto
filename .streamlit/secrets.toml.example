# Streamlit Secrets Configuration Example
# Copy this file to secrets.toml and add your actual credentials

# Binance Testnet Credentials (for testing)
BINANCE_TESTNET_API_KEY = "your_testnet_api_key_here"
BINANCE_TESTNET_API_SECRET = "your_testnet_api_secret_here"

# Binance Production Credentials (optional - use with caution)
# BINANCE_API_KEY = "your_production_api_key_here"
# BINANCE_API_SECRET = "your_production_api_secret_here"
